---
import { getRelativeLocaleUrl } from 'astro:i18n';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { locales, type Locale, useTranslations } from '../../../i18n/ui';
import { getLocalePostSummaries } from '../../../lib/posts';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);
const recentPosts = (await getLocalePostSummaries(lang)).slice(0, 3);
---

<SiteLayout
  lang={lang}
  title={`${t('authorName')} · ${t('navProjects')}`}
  description={t('projectsIntro')}
  pathname={Astro.url.pathname}
  recentPosts={recentPosts}
>
  <section class="grid gap-8">
    <header class="surface glow-card rounded-[2rem] p-8 sm:p-10 lg:p-12">
      <div class="max-w-3xl space-y-5">
        <span class="pill">{t('navProjects')}</span>
        <h1 class="text-5xl leading-[0.95] sm:text-6xl">{t('projectsHeading')}</h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--text-muted)]">{t('projectsIntro')}</p>
      </div>
    </header>

    <div class="grid gap-6 lg:grid-cols-3">
      <ProjectCard
        status={t('projectPlaceholder1Status')}
        title={t('projectPlaceholder1Title')}
        description={t('projectPlaceholder1Description')}
        tags={[
          t('projectPlaceholder1Tag1'),
          t('projectPlaceholder1Tag2'),
          t('projectPlaceholder1Tag3'),
        ]}
        linkLabel={t('viewProject')}
      />
      <ProjectCard
        status={t('projectPlaceholder2Status')}
        title={t('projectPlaceholder2Title')}
        description={t('projectPlaceholder2Description')}
        tags={[
          t('projectPlaceholder2Tag1'),
          t('projectPlaceholder2Tag2'),
          t('projectPlaceholder2Tag3'),
        ]}
        linkLabel={t('viewProject')}
      />
      <ProjectCard
        status={t('projectPlaceholder3Status')}
        title={t('projectPlaceholder3Title')}
        description={t('projectPlaceholder3Description')}
        tags={[
          t('projectPlaceholder3Tag1'),
          t('projectPlaceholder3Tag2'),
          t('projectPlaceholder3Tag3'),
        ]}
        linkLabel={t('viewProject')}
      />
    </div>

    <a
      href={getRelativeLocaleUrl(lang, 'about')}
      class="surface glow-card flex items-center justify-between rounded-[1.5rem] px-6 py-5 font-semibold text-[color:var(--text)] transition hover:-translate-y-0.5 hover:text-[color:var(--accent)]"
    >
      <span>{t('navAbout')}</span>
      <span aria-hidden="true">→</span>
    </a>
  </section>
</SiteLayout>
