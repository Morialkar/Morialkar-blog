---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { render } from 'astro:content';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { useTranslations } from '../../../i18n/ui';
import { formatDate, getLocalePosts, getPostLocale, getPostSlug, type BlogPost } from '../../../lib/posts';

export async function getStaticPaths() {
  const posts = await getLocalePosts('fr');
  const english = await getLocalePosts('en');

  return [...posts, ...english].map((post) => ({
    params: { lang: getPostLocale(post), slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props as { post: BlogPost };
const lang = getPostLocale(post);
const t = useTranslations(lang);
const posts: BlogPost[] = await getLocalePosts(lang);
const summaries = posts.map((entry: BlogPost) => ({
  href: `/${lang}/blog/${getPostSlug(entry)}/`,
  title: entry.data.title,
  dateLabel: formatDate(entry.data.pubDate, lang),
  category: entry.data.category,
  heroImage: entry.data.heroImage,
}));
const currentIndex = posts.findIndex((entry: BlogPost) => entry.id === post.id);
const newerPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 && currentIndex < posts.length - 1 ? posts[currentIndex + 1] : undefined;
const { Content } = await render(post);
---

<SiteLayout
  lang={lang}
  title={`${post.data.title} · Naomi`}
  description={post.data.description}
  pathname={Astro.url.pathname}
  recentPosts={summaries.slice(0, 3)}
>
  <article class="grid gap-8">
    <header class="surface glow-card overflow-hidden rounded-[2rem]">
      {post.data.heroImage && (
        <img src={post.data.heroImage} alt="" class="h-[22rem] w-full object-cover" />
      )}
      <div class="space-y-5 p-8 sm:p-10 lg:p-12">
        <span class="pill">{post.data.category}</span>
        <h1 class="max-w-4xl text-5xl leading-[0.92] sm:text-6xl lg:text-7xl">{post.data.title}</h1>
        <p class="max-w-3xl text-lg leading-8 text-[color:var(--text-muted)]">{post.data.description}</p>
        <p class="text-sm font-medium text-[color:var(--text-muted)]">
          {t('postedOn')} <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, lang)}</time> · {t('by')} {t('authorName')}
        </p>
      </div>
    </header>

    <article class="content-body surface rounded-[2rem] px-8 py-10 sm:px-10 lg:px-12">
      <Content />
    </article>

    <footer class="surface glow-card rounded-[2rem] p-6 sm:p-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <a
          href={getRelativeLocaleUrl(lang, 'blog')}
          class="rich-link inline-flex items-center gap-2 font-semibold text-[color:var(--accent)]"
        >
          ← {t('backToBlog')}
        </a>
        <div class="flex flex-wrap gap-3 text-sm font-semibold">
          {newerPost && (
            <a
              href={`/${lang}/blog/${getPostSlug(newerPost)}/`}
              class="rounded-full border border-[color:var(--border)] bg-white px-4 py-2 transition hover:border-[color:var(--accent)] hover:text-[color:var(--accent)]"
            >
              ← Newer post
            </a>
          )}
          {olderPost && (
            <a
              href={`/${lang}/blog/${getPostSlug(olderPost)}/`}
              class="rounded-full border border-[color:var(--border)] bg-white px-4 py-2 transition hover:border-[color:var(--accent)] hover:text-[color:var(--accent)]"
            >
              Older post →
            </a>
          )}
        </div>
      </div>
    </footer>
  </article>
</SiteLayout>
