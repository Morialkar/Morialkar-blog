---
const fallback = '/fr/';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        var lang = (navigator.language || 'fr').toLowerCase();
        var target = lang.indexOf('en') === 0 ? '/en/' : '/fr/';
        window.location.replace(target);
      })();
    </script>
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={fallback} />
    <title>Naomi — redirection</title>
  </head>
  <body>
    <a href={fallback}>Redirecting to <code>{fallback}</code>…</a>
  </body>
</html>
