---
import { ui } from '../i18n/ui';

const fallback = '/fr/';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        var lang = (navigator.language || 'fr').toLowerCase();
        var target = lang.indexOf('en') === 0 ? '/en/' : '/fr/';
        window.location.replace(target);
      })();
    </script>
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={fallback} />
    <title>Naomi · Morialkar</title>
    <style>
      body {
        min-height: 100vh;
        display: grid;
        place-items: center;
        margin: 0;
        background: linear-gradient(180deg, #fff0f7 0%, #ffd6ec 100%);
        color: #2a0a2e;
        font-family: system-ui, sans-serif;
      }
      a {
        color: #e6007e;
      }
    </style>
  </head>
  <body>
    <main>
      <p>
        <span lang="fr">{ui.fr.redirectingTo} <a href={fallback}>/fr/</a>…</span>
        /
        <span lang="en">{ui.en.redirectingTo} <a href={fallback}>/fr/</a>…</span>
      </p>
    </main>
  </body>
</html>
