---
type Props = {
  title: string;
  description: string;
  status: string;
  link?: string;
  tags: string[];
};

const { title, description, status, link, tags } = Astro.props as Props;
---

<article class="surface glow-card rounded-[1.75rem] p-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <span class="pill mb-4">{status}</span>
      <h2 class="text-2xl">{title}</h2>
    </div>
    <div class="rounded-full bg-[color:var(--accent-soft)] p-3 text-[color:var(--accent)]">✦</div>
  </div>
  <p class="mt-4 text-sm leading-7 text-[color:var(--text-muted)]">{description}</p>
  <div class="mt-6 flex flex-wrap gap-2">
    {tags.map((tag) => <span class="rounded-full border border-[color:var(--border)] bg-white/75 px-3 py-1 text-xs font-semibold text-[color:var(--text-muted)]">{tag}</span>)}
  </div>
  {link && (
    <a href={link} class="rich-link mt-6 inline-flex font-semibold text-[color:var(--accent)]">
      View project
    </a>
  )}
</article>
