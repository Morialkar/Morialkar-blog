---
type Props = {
  summary: {
    href: string;
    title: string;
    description: string;
    category: string;
    dateLabel: string;
    heroImage?: string;
    tags: string[];
  };
};

const { summary } = Astro.props as Props;
---

<article class="surface glow-card group overflow-hidden rounded-[1.75rem] transition duration-300 hover:-translate-y-1">
  {summary.heroImage && (
    <a href={summary.href} class="block overflow-hidden">
      <img
        src={summary.heroImage}
        alt=""
        class="h-48 w-full object-cover transition duration-500 group-hover:scale-[1.03]"
        loading="lazy"
      />
    </a>
  )}
  <div class="space-y-4 p-6">
    <div class="flex flex-wrap items-center gap-3">
      <span class="pill">{summary.category}</span>
      <time class="text-sm font-medium text-[color:var(--text-muted)]">{summary.dateLabel}</time>
    </div>
    <div class="space-y-3">
      <h2 class="text-2xl leading-tight">
        <a href={summary.href} class="rich-link text-[color:var(--text)] transition hover:text-[color:var(--accent)]">
          {summary.title}
        </a>
      </h2>
      <p class="text-sm leading-7 text-[color:var(--text-muted)]">{summary.description}</p>
    </div>
    <div class="flex flex-wrap gap-2">
      {summary.tags.map((tag) => <span class="rounded-full bg-[color:var(--bg-soft)] px-3 py-1 text-xs font-semibold text-[color:var(--text-muted)]">{tag}</span>)}
    </div>
  </div>
</article>
